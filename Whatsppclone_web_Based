<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WhatsApp UI Clone</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, sans-serif;
    }

    body{
      background:#d9dbd5;
      height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      padding:20px;
    }

    .container{
      width:100%;
      max-width:1200px;
      height:90vh;
      background:#fff;
      display:flex;
      overflow:hidden;
      border-radius:10px;
      box-shadow:0 4px 10px rgba(0,0,0,0.2);
    }

    /* LEFT CHAT LIST */

    .chat-list{
      width:35%;
      background:#ffffff;
      border-right:1px solid #ddd;
      display:flex;
      flex-direction:column;
    }

    .chat-header{
      background:#075E54;
      color:white;
      padding:18px;
      font-size:20px;
      font-weight:bold;
    }

    .chat-item{
      display:flex;
      align-items:center;
      padding:15px;
      border-bottom:1px solid #f1f1f1;
      cursor:pointer;
      transition:0.3s;
    }

    .chat-item:hover{
      background:#f5f5f5;
    }

    .avatar{
      width:50px;
      height:50px;
      border-radius:50%;
      background:#25D366;
      margin-right:15px;
    }

    .chat-info h4{
      font-size:16px;
      margin-bottom:5px;
      color:#222;
    }

    .chat-info p{
      font-size:14px;
      color:gray;
    }

    /* RIGHT CHAT WINDOW */

    .chat-window{
      width:65%;
      display:flex;
      flex-direction:column;
      background:#ece5dd;
    }

    .window-header{
      background:#075E54;
      color:white;
      padding:15px;
      display:flex;
      align-items:center;
    }

    .window-header .avatar{
      margin-right:10px;
    }

    .messages{
      flex:1;
      padding:20px;
      overflow-y:auto;
    }

    .message{
      max-width:70%;
      padding:12px;
      margin-bottom:15px;
      border-radius:10px;
      font-size:14px;
    }

    .received{
      background:white;
    }

    .sent{
      background:#DCF8C6;
      margin-left:auto;
    }

    /* INPUT AREA */

    .input-area{
      display:flex;
      padding:15px;
      background:#f0f0f0;
    }

    .input-area input{
      flex:1;
      padding:12px;
      border:none;
      border-radius:25px;
      outline:none;
      font-size:14px;
    }

    .input-area button{
      margin-left:10px;
      padding:12px 20px;
      border:none;
      border-radius:25px;
      background:#25D366;
      color:white;
      cursor:pointer;
      font-size:14px;
      transition:0.3s;
    }

    .input-area button:hover{
      background:#1ebe5d;
    }

    /* RESPONSIVE DESIGN */

    @media(max-width:768px){

      .container{
        flex-direction:column;
        height:100vh;
      }

      .chat-list{
        width:100%;
        height:35%;
      }

      .chat-window{
        width:100%;
        height:65%;
      }
    }

  </style>
</head>

<body>

  <div class="container">

    <!-- LEFT PANEL -->

    <div class="chat-list">

      <div class="chat-header">
        WhatsApp
      </div>

      <div class="chat-item">
        <div class="avatar"></div>

        <div class="chat-info">
          <h4>Ali Khan</h4>
          <p>Hello! How are you?</p>
        </div>
      </div>

      <div class="chat-item">
        <div class="avatar"></div>

        <div class="chat-info">
          <h4>Ahmed</h4>
          <p>Let's meet tomorrow.</p>
        </div>
      </div>

      <div class="chat-item">
        <div class="avatar"></div>

        <div class="chat-info">
          <h4>Usman</h4>
          <p>Project completed.</p>
        </div>
      </div>

    </div>

    <!-- RIGHT CHAT WINDOW -->

    <div class="chat-window">

      <div class="window-header">
        <div class="avatar"></div>
        <h3>Ali Khan</h3>
      </div>

      <div class="messages">

        <div class="message received">
          Hi! This is a WhatsApp UI clone.
        </div>

        <div class="message sent">
          Looks clean and responsive.
        </div>

        <div class="message received">
          Great job!
        </div>

      </div>

      <!-- INPUT -->

      <div class="input-area">
        <input type="text" placeholder="Type a message">
        <button>Send</button>
      </div>

    </div>

  </div>

</body>
</html>
